# Токен Telegram бота
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ID администратора
ADMIN_ID=385450652
ADMIN_PASSWORD=YOUR_STRONG_ADMIN_PASSWORD
SESSION_COOKIE_SECURE=true
ADMIN_MAX_LOGIN_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_SECONDS=900
ADMIN_LOCKOUT_SECONDS=900

# FatSecret API
FATSECRET_CLIENT_ID=YOUR_FATSECRET_CLIENT_ID
FATSECRET_CLIENT_SECRET=YOUR_FATSECRET_CLIENT_SECRET
USE_FATSECRET=true

# ЮKassa платежи
YOOKASSA_SHOP_ID=YOUR_YOOKASSA_SHOP_ID
YOOKASSA_SECRET_KEY=YOUR_YOOKASSA_SECRET_KEY
YOOKASSA_PROVIDER_TOKEN=YOUR_YOOKASSA_PROVIDER_TOKEN

# OpenAI API
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_ENABLED=true

# AITunnel API (для работы в РФ)
AITUNNEL_API_KEY=YOUR_AITUNNEL_API_KEY

# GigaChat API (Российский аналог OpenAI)
GIGACHAT_CREDENTIALS=YOUR_GIGACHAT_CREDENTIALS

# База данных
DATABASE_URL=sqlite+aiosqlite:///fitness_bot.db

# Часовой пояс
SERVER_TIMEZONE=Europe/Moscow

# Настройки экспорта
EXPORT_PATH=exports

# Настройки подписки
STARS_PRICE=20
SUBSCRIPTION_DAYS=30
